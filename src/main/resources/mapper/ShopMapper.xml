<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.study.myproject01.shop.mapper.ShopMapper">
    <select id="getShopList" parameterType="String" resultType="ShopVO">
        select * from shop_t where p_active = 0 and category=#{category} order by shop_idx desc
    </select>
    <select id="getShopDetail" parameterType="ShopVO" resultType="ShopVO">
        select * from shop_t where shop_idx = #{shop_idx}
    </select>
</mapper>